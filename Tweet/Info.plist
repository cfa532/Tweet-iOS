<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
	<key>UIFileSharingEnabled</key>
	<true/>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.zz.upload</string>
		<string>com.example.ZZ.messageCheck</string>
		<string>com.example.ZZ.mainFeedCheck</string>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
	</array>
	<key>CFBundleLocalizations</key>
	<array>
		<string>en</string>
		<string>zh-Hans</string>
		<string>ja</string>
	</array>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>NSCameraUsageDescription</key>
	<string>We need access to your camera to take photos and videos for your posts.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>We need access to your microphone to record videos with audio for your posts.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>We need access to your photo library to select photos and videos to share in your posts.</string>
	<key>NSUserNotificationUsageDescription</key>
	<string>We need to send you notifications about new messages, replies, and interactions.</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>tweet</string>
			</array>
			<key>CFBundleURLName</key>
			<string>com.tweet.deeplink</string>
		</dict>
	</array>
</dict>
</plist>
